program
{
	int i;
	double d;
	bool b;

	b = true && false;
	write b;
	write "\n";
	
	b = true && false;
	write b;
	write "\n";

	b = true && true;
	write b;
	write "\n";

	b = false && false;
	write b;
	write "\n";

	b = true || false;
	write b;
	write "\n";
	
	b = true || false;
	write b;
	write "\n";

	b = false || false;
	write b;
	write "\n";
} 
